@model BoardDto
@{
    ViewData["Title"] = "Delete Board";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h1 class="h3 text-danger mb-3">Delete board</h1>
        <p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
        <p class="text-secondary">This will also remove all lists and tasks inside the board.</p>

        <form method="post">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </form>
    </div>
</div>
