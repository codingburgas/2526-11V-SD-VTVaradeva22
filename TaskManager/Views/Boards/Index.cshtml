@model IReadOnlyCollection<BoardDto>
@{
    ViewData["Title"] = "Boards";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">Boards</h1>
        <p class="text-secondary mb-0">Manage project spaces and open each board in Kanban view.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create Board</a>
</div>

<div class="row g-4">
    @foreach (var board in Model)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="h5 mb-1">@board.Name</h2>
                            <p class="text-secondary small mb-0">Owner: @board.OwnerName</p>
                        </div>
                        <span class="badge rounded-pill text-bg-primary">@board.TotalTasks tasks</span>
                    </div>
                    <p class="text-secondary">@board.Description</p>
                    <div class="d-flex gap-3 small text-secondary mb-4">
                        <span>Done: @board.CompletedTasks</span>
                        <span>Pending: @board.PendingTasks</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-outline-primary btn-sm" asp-action="Details" asp-route-id="@board.Id">Open</a>
                        <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@board.Id">Edit</a>
                        <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@board.Id">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
