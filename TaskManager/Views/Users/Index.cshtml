@model IReadOnlyCollection<UserManagementViewModel>
@{
    ViewData["Title"] = "Users";
}

<div class="mb-4">
    <h1 class="h2 mb-1">User Management</h1>
    <p class="text-secondary mb-0">Admin area for reviewing roles and user activity.</p>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Assigned Tasks</th>
                <th>Completed Tasks</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                    <td>@user.AssignedTasks</td>
                    <td>@user.CompletedTasks</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@user.Id">Edit Role</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
