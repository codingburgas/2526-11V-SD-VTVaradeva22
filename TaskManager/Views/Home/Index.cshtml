@{
    ViewData["Title"] = "Home";
}

<section class="hero-card hero-shell rounded-4">
    <div class="row align-items-center g-4 g-xl-5">
        <div class="col-xl-6">
            <span class="badge soft-badge mb-3">Kanban Task Manager</span>
            <h1 class="display-5 fw-bold">Organize boards, lists and tasks in one calm, stylish workflow.</h1>
            <p class="lead hero-lead mt-3">
                Build project boards, move tasks through status columns, assign deadlines and track progress with a softer, more polished workspace.
            </p>
            <div class="d-flex flex-wrap gap-2 mt-4">
                <a class="btn btn-primary btn-lg" asp-controller="Account" asp-action="Login">Start Working</a>
                <a class="btn btn-outline-primary btn-lg" asp-controller="Account" asp-action="Register">Create Account</a>
            </div>
            <div class="hero-mini-stats mt-4">
                <div class="hero-mini-stat">
                    <strong>Boards & Lists</strong>
                    <span>Clear structure for every project.</span>
                </div>
                <div class="hero-mini-stat">
                    <strong>Task Tracking</strong>
                    <span>Priorities, deadlines and assignments in one place.</span>
                </div>
                <div class="hero-mini-stat">
                    <strong>Live Dashboard</strong>
                    <span>Weekly progress and upcoming deadlines at a glance.</span>
                </div>
            </div>
        </div>
        <div class="col-xl-6">
            <div class="hero-visual-wrap">
                <img class="hero-visual-image" src="~/images/hero-collage.svg" alt="Pastel editorial task management collage" />
                <div class="hero-floating-card hero-floating-card-top">
                    <span class="hero-floating-tag">Soft Planning</span>
                    <strong>Boards that feel calm and focused</strong>
                    <p>Pastel UI, clear hierarchy and a more boutique visual style.</p>
                </div>
                <div class="hero-floating-card hero-floating-card-bottom">
                    <span class="hero-floating-tag">Weekly Rhythm</span>
                    <strong>Track progress without visual noise</strong>
                    <p>Useful stats, cleaner spacing and a smoother first impression.</p>
                </div>
            </div>
        </div>
    </div>
</section>
